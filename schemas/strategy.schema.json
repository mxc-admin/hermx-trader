{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kftradingsystem.local/schemas/strategy.schema.json",
  "title": "Kinetic Flow Strategy File",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "strategy_id",
    "name",
    "asset",
    "okx_inst_id",
    "timeframe",
    "chart_type",
    "indicator",
    "indicator_version",
    "upper_band_mult",
    "lower_band_mult",
    "auto_alpha",
    "budget_usd",
    "leverage",
    "margin_mode",
    "execution_mode",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "strategy_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "asset": {
      "type": "string",
      "pattern": "^[A-Z0-9]+USDT$"
    },
    "okx_inst_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+-USDT-SWAP$"
    },
    "timeframe": {
      "type": "string",
      "enum": ["30m", "1h", "2h", "3h", "4h"]
    },
    "chart_type": {
      "type": "string",
      "enum": ["heikin_ashi"]
    },
    "indicator": { "type": "string", "minLength": 1 },
    "indicator_version": { "type": "string", "minLength": 1 },
    "upper_band_mult": { "type": "number", "exclusiveMinimum": 0 },
    "lower_band_mult": { "type": "number", "exclusiveMinimum": 0 },
    "auto_alpha": { "type": "boolean" },
    "budget_usd": { "type": "number", "exclusiveMinimum": 0 },
    "leverage": { "type": "number", "exclusiveMinimum": 0 },
    "margin_mode": {
      "type": "string",
      "enum": ["isolated"]
    },
    "execution_mode": {
      "type": "string",
      "enum": ["demo", "paper", "shadow"]
    },
    "okx_submit_orders": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": ["trial_candidate", "active_demo", "paper_only", "disabled"]
    },
    "notes": { "type": "string" },
    "validation_source": { "type": "string" }
  }
}
