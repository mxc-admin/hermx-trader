# Copy to .env and fill locally or on the VPS.
# Do not commit real secrets.

# Unified secret: ONE value authenticates BOTH the webhook (X-Webhook-Secret) and
# the dashboard (X-Dashboard-Token / Bearer / Basic password). Generate with
# `openssl rand -hex 32`. run.sh creates one automatically on first run if blank.
# This is the SOLE source for auth; if blank, auth fails closed (401).
HERMX_SECRET=
HERMX_REQUIRE_HMAC=false
HERMX_WEBHOOK_HMAC_KEY=
HERMX_REPLAY_WINDOW_SECONDS=300
HERMX_MAX_BODY_BYTES=262144
HERMX_RATE_LIMIT_WINDOW_SECONDS=60
HERMX_RATE_LIMIT_MAX_REQUESTS=120
HERMX_QUEUE_MAXSIZE=200
HERMX_SUBMIT_TIMEOUT_SECONDS=45
# Global live-trading kill switch. demo/paper execution_mode strategies ignore it
# and always sandbox.
# Flip to true ONLY when going live with a real (non-sandbox) exchange account
HERMX_LIVE_TRADING=false
# Execution backend. CCXT is the sole backend; leave unset (recommended) and the
# adapter is selected from the runtime profile's execution.exchange. An explicit
# value is honored only as an override and maps to CCXT.
# HERMX_EXEC_BACKEND=ccxt
HERMX_WORKER_POOL_SIZE=1
HERMX_SIGNAL_DEDUPE_WINDOW_SECONDS=86400
HERMX_WATCHDOG_ENABLED=true
HERMX_WATCHDOG_STALE_SECONDS=120
HERMX_QUEUE_LAG_SLO_SECONDS=30

SHADOW_PORT=8891
CLEAN_DASHBOARD_PORT=8098
HERMX_DASH_AUTH=true
# Dashboard auth uses HERMX_SECRET (set near the top); it is the only token source.

# --- Pre-execution advisor (Hermes Agent) ---
# Optional. HERMX_ADVISOR_ENABLED is a SINGLE LIVE-VETO switch, default OFF: leave it
# unset/false and the advisor is never consulted (execution byte-identical). Turn it on
# and a 'skip' verdict BLOCKS the trade — there is no annotate-only mode. It fails open:
# a missing/slow/garbage Hermes reply records the error and proceeds deterministically.
# HERMX_ADVISOR_ENABLED=false
# HERMX_ADVISOR_COMMAND=hermes          # the Hermes CLI on PATH
# HERMX_ADVISOR_SKILLS=hermx-control    # comma-separated skills to load
# HERMX_ADVISOR_MODEL=                  # optional -m override; empty = Hermes default
# HERMX_ADVISOR_TIMEOUT_SECONDS=30      # the agent loop is heavier than a raw call

# --- Networking / state location ---
# Address the receiver + dashboard HTTP servers bind to. Leave UNSET for
# local/host deploys (defaults to 127.0.0.1). The Docker bridge compose sets
# HERMX_BIND_HOST=0.0.0.0 per-service; do NOT set it to 0.0.0.0 here for a bare
# host install or you will expose the ports on every interface.
# HERMX_BIND_HOST=127.0.0.1
# Directory for the four mutable state snapshots (paper-state, control-state,
# seen-signals, latest). Leave UNSET for local/host deploys (defaults to the repo
# root). The Docker bridge compose sets HERMX_DATA_DIR=/app/data (a named volume).
# HERMX_DATA_DIR=

# --- Tailscale (default public ingress for the Docker deploy) ---
# Reusable/ephemeral auth key for the tailscale sidecar in docker-compose.yml.
# Generate it in the Tailscale admin console (Settings -> Keys). The sidecar joins
# your tailnet as 'hermx', Funnels https -> receiver:8891, and serves the dashboard
# tailnet-only on :8443. Leave blank for host setups (the host's own Tailscale).
TS_AUTHKEY=
# Where the tailscale node persists its identity/state inside the container.
# Optional — defaults to /var/lib/tailscale (the mounted tailscale-state volume).
TS_STATE_DIR=/var/lib/tailscale

# Legacy OKX vars (backward compatible)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_FORCE_IPV4=1

# Namespaced per-exchange credentials (preferred)
OKX_DEMO_API_KEY=
OKX_DEMO_SECRET_KEY=
OKX_DEMO_PASSPHRASE=

KUCOIN_PAPER_API_KEY=
KUCOIN_PAPER_SECRET=
KUCOIN_PAPER_PASSPHRASE=

BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_SECRET_KEY=
